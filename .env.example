# Konfigurasi API AI (Pilih salah satu atau isi keduanya)
# Saya merekomendasikan Groq karena sangat cepat untuk Whisper
GROQ_API_KEY=gsk_your_key_here
OPENAI_API_KEY=sk-your_key_here

# Konfigurasi Whisper Lokal (Jika tidak pakai API)
# Pilihan: tiny, base, small, medium, large
WHISPER_MODEL=medium

# Gaya Subtitle (Pilihan: tiktok, netflix, anime, minimalist)
SUBTITLE_STYLE=tiktok

